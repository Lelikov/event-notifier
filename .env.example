# RabbitMQ — queue name/arguments are fixed by event_schemas.queues (events.notification.commands)
RABBIT_URL=amqp://guest:guest@localhost:5672/
RABBIT_EXCHANGE=events
CONSUMER_PREFETCH_COUNT=10
GRACEFUL_TIMEOUT=30

# PostgreSQL (async driver required)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/event_notifier

# event-users (contact resolution)
EVENT_USERS_URL=http://localhost:8001
EVENT_USERS_TOKEN=<bearer-token>

# event-receiver ingest for delivery-result events (optional; unset disables result publishing)
EVENTS_ENDPOINT_URL=http://localhost:8000/event/admin
EVENTS_API_KEY=<admin-api-key>

# Email (UniSender Go). Template IDs are the UUIDs of templates provisioned in UniSender Go,
# one per TriggerEvent. Missing entries fail the email permanently (no retries).
UNISENDER_API_KEY=<api-key>
UNISENDER_FROM_EMAIL=noreply@yourdomain.com
UNISENDER_FROM_NAME=Your Service
# Locale-keyed (preferred); the legacy flat {"BOOKING_CREATED":"<uuid>",...} form is read as DEFAULT_LOCALE.
UNISENDER_TEMPLATE_IDS={"ru":{"BOOKING_CREATED":"<uuid>","BOOKING_CANCELLED":"<uuid>","BOOKING_RESCHEDULED":"<uuid>","BOOKING_REASSIGNED":"<uuid>","BOOKING_REMINDER":"<uuid>","BOOKING_REJECTED":"<uuid>"},"en":{"BOOKING_CREATED":"<uuid>"}}
# Default template language for recipients without a known locale
DEFAULT_LOCALE=ru

# Telegram Bot
TELEGRAM_BOT_TOKEN=<bot-token>

# FCM (optional — PushChannel is wired but disabled)
FCM_PROJECT_ID=<firebase-project-id>
FCM_SERVICE_ACCOUNT_JSON=<path-to-service-account.json>

DEBUG=false
LOG_LEVEL=INFO
